[node name="Objects" type="Node2D" parent="." unique_id=2127655025]

[node name="Bookshelf" type="TileMapLayer" parent="Objects" unique_id=1228590991]
texture_filter = 1
scale = Vector2(1.85, 1.85)
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Bookshelf" unique_id=1528159075]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
scale = Vector2(0.9999999, 0.9999999)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("4_xrqjs")
ExamineText = "(...)"
DialogueDuration = 2.0

[node name="Examine1" type="TileMapLayer" parent="Objects/Bookshelf" unique_id=1198979939]
texture_filter = 1
scale = Vector2(0.99999994, 0.99999994)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("5_rr3dr")
ExamineText = "\"A book is missing. The gap is exact — not scattered, not collapsed inward. Someone took one book.\""
DialogueDuration = 5.0
DialogueFontSize = 26

[node name="Phone" type="TileMapLayer" parent="Objects" unique_id=872612347]
texture_filter = 1
scale = Vector2(3, 3)
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Phone" unique_id=1653338087]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAAFAAEAAAAXAAwAAAAFAAIAAAAXAA0AAAAFAAMAAAAXAA4AAAAFAAQAAAAXAA8AAAAFAAUAAAAXABAAAAAGAAEAAAAYAAwAAAAGAAIAAAAYAA0AAAAGAAMAAAAYAA4AAAAGAAQAAAAYAA8AAAAGAAUAAAAYABAAAAAHAAEAAAAZAAwAAAAHAAIAAAAZAA0AAAAHAAMAAAAZAA4AAAA=")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("6_bxwnc")
ExamineText = "\"Someone held this phone while being told something.\"|\"They held it for a long time.\"|\"When they put it down, they weren't careful.\""

[node name="Examine2" type="TileMapLayer" parent="Objects/Phone" unique_id=550287338]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAAFAAEAAAATAAwAAAAFAAIAAAATAA0AAAAFAAMAAAATAA4AAAAFAAQAAAATAA8AAAAFAAUAAAATABAAAAAGAAEAAAAUAAwAAAAGAAIAAAAUAA0AAAAGAAMAAAAUAA4AAAA=")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("7_5t2x5")
ExamineText = "\"The cord is perfectly untangled. Someone straightened it. That's not how phones look after use.\""
DialogueDuration = 4.0
DialogueFontSize = 27

[node name="Examine1" type="TileMapLayer" parent="Objects/Phone" unique_id=1518922309]
texture_filter = 1
tile_map_data = PackedByteArray("AAAFAAEAAAATAAwAAAAFAAIAAAATAA0AAAAFAAMAAAATAA4AAAAFAAQAAAATAA8AAAAFAAUAAAATABAAAAAGAAEAAAAUAAwAAAAGAAIAAAAUAA0AAAAGAAMAAAAUAA4AAAA=")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("8_vyxdy")
ExamineText = "\"An old phone. The kind with a satisfying click when it connects.\"|\"She used to love the sound of it ringing.\""
DialogueDurationText = "4.0|3.0"
DialogueFontSize = 27

[node name="Photo" type="TileMapLayer" parent="Objects" unique_id=606637922]
texture_filter = 1
scale = Vector2(1.5, 1.5)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")

[node name="Table" type="TileMapLayer" parent="Objects" unique_id=263220982]
texture_filter = 1
scale = Vector2(2.5, 2.5)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")

[node name="Painting" type="TileMapLayer" parent="Objects" unique_id=1346424177]
texture_filter = 1
scale = Vector2(1.5, 1.5)
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Painting" unique_id=1491523078]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("9_ihi4w")
ExamineText = "\"The Memory made them equal. It is easier, in memory, to have a sister who was a peer rather than a child you were supposed to be watching.\""
DialogueDuration = 6.0
DialogueFontSize = 25

[node name="Examine2" type="TileMapLayer" parent="Objects/Painting" unique_id=1255215573]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("10_wrmhd")
ExamineText = "\"They're the same height. They weren't the same height. She was eight years younger.\""
DialogueDuration = 5.0
DialogueFontSize = 27

[node name="Examine1" type="TileMapLayer" parent="Objects/Painting" unique_id=1158125527]
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("11_t8ro7")
ExamineText = "(Two figures, the same height. 'Mara' and 'Ida.' Both of them careful, labeled so no one would forget.)|\"She always labeled her drawings.\""
DialogueDurationText = "6.0|3.0"
DialogueFontSize = 27

[node name="LeftChair" type="TileMapLayer" parent="Objects" unique_id=1126237310]
texture_filter = 1
scale = Vector2(3, 3)
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/LeftChair" unique_id=1422996788]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("12_sboqf")
ExamineText = "\"This chair was used. This is accurate.\""

[node name="Examine2" type="TileMapLayer" parent="Objects/LeftChair" unique_id=1535688709]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("13_j1llv")
ExamineText = "\"The indentation in the cushion. Someone sat here often. The blanket smells like cedar.\""
DialogueDuration = 5.0
DialogueFontSize = 27

[node name="Examine1" type="TileMapLayer" parent="Objects/LeftChair" unique_id=827890139]
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("14_krsfi")
ExamineText = "\"She always took this one. Said it was the better light.\"|\"She'd fall asleep here with a book still open on her chest.\""
DialogueDurationText = "4.0|5.0"
DialogueFontSize = 27

[node name="RightChair" type="TileMapLayer" parent="Objects" unique_id=895388815]
texture_filter = 1
scale = Vector2(3, 3)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/RightChair" unique_id=292528287]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("15_uko4f")
ExamineText = "\"Only one chair has a cushion indentation. The other chair is the one she pulled in later. For company she was imagining.\""
DialogueDuration = 5.0
DialogueFontSize = 25

[node name="Examine2" type="TileMapLayer" parent="Objects/RightChair" unique_id=585344597]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("16_6wdia")
ExamineText = "\"The cushion is firm. Less sat-in than the other.\""

[node name="Examine1" type="TileMapLayer" parent="Objects/RightChair" unique_id=1824076315]
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("17_qa58q")
ExamineText = "\"This was yours. You sat here while she read aloud. You didn't always listen, but you were always there.\""
DialogueDuration = 5.0
DialogueFontSize = 24

[node name="Globe" type="TileMapLayer" parent="Objects" unique_id=1504758163]
texture_filter = 1
scale = Vector2(1.45, 1.45)
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Globe" unique_id=1483682864]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
scale = Vector2(0.9999999, 0.9999999)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("18_5t2x5")
ExamineText = "\"Turned to face the wall. Someone did that deliberately. Some things stay hidden.\"
"
DialogueDuration = 5.0
DialogueFontSize = 28

[node name="Examine2" type="TileMapLayer" parent="Objects/Globe" unique_id=1575263554]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
scale = Vector2(0.9999999, 0.9999999)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("19_vyxdy")
ExamineText = "\"It still spins. It always faces the same direction when it stops.\""
DialogueDuration = 4.0

[node name="Examine1" type="TileMapLayer" parent="Objects/Globe" unique_id=1780471606]
texture_filter = 1
scale = Vector2(0.99999994, 0.99999994)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("20_ihi4w")
ExamineText = "(A heavy globe, the kind that lives in family studies for decades.)|\"She used to spin it and stop it with one finger and go wherever it landed.\""
DialogueDurationText = "4.0|5.0"
DialogueFontSize = 27

[node name="Letter" type="TileMapLayer" parent="Objects" unique_id=794578519]
texture_filter = 1
rotation = -6.2831855
scale = Vector2(0.785, 0.785)
skew = -1.0471976
tile_set = SubResource("TileSet_elej8")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Letter" unique_id=619236568]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
scale = Vector2(1, 0.9999998)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("18_bejpq")
ExamineText = "\"We are so proud of you.\"|Written after. One daughter left. They wrote it to be kind and they were kind but she could see what wasn't written and she kept it anyway because there was nothing else.\""
DialogueDurationText = "3.0|6.0"
DialogueFontSize = 26

[node name="Examine2" type="TileMapLayer" parent="Objects/Letter" unique_id=965223144]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
scale = Vector2(1, 0.9999998)
tile_map_data = PackedByteArray("")
tile_set = SubResource("TileSet_elej8")
script = ExtResource("19_yhq2u")
ExamineText = "\"We are so proud of both our — \"|(....)|\"The letter is shorter than you remember. It may have always been shorter.\""
