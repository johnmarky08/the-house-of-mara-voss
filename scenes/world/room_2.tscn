[sub_resource type="TileSet" id="TileSet_elej8"]
sources/0 = SubResource("TileSetAtlasSource_wlug7")

[node name="Room2" type="TileMapLayer" unique_id=927437449]
tile_set = ExtResource("1_j1llv")

[node name="Background" type="Sprite2D" parent="." unique_id=1699132744]
z_index = -1
position = Vector2(576, 324)
scale = Vector2(0.6784452, 0.699784)
