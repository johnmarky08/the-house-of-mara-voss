[node name="Examine2" type="TileMapLayer" parent="Objects/Toast" unique_id=1675839815]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAAXAA8ABAAIAAYAAAAXABAABAAIAAcAAAAXABEABAAIAAgAAAAYAA8ABAAJAAYAAAAYABAABAAJAAcAAAAYABEABAAJAAgAAAAZAA8ABAAKAAYAAAAZABAABAAKAAcAAAAZABEABAAKAAgAAAAaAA8ABAALAAYAAAAaABAABAALAAcAAAAaABEABAALAAgAAAA=")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("11_toast_examine2")
ExamineText = "(You imagined the bite. The toast is untouched. No one has eaten here.)"
DialogueDuration = 5.0
DialogueFontSize = 28

[node name="Examine1" type="TileMapLayer" parent="Objects/Toast" unique_id=499277942]
texture_filter = 1
tile_map_data = PackedByteArray("AAAXAA8ABAACAAYAAAAXABAABAACAAcAAAAXABEABAACAAgAAAAYAA8ABAADAAYAAAAYABAABAADAAcAAAAYABEABAADAAgAAAAZAA8ABAAEAAYAAAAZABAABAAEAAcAAAAZABEABAAEAAgAAAAaAA8ABAAFAAYAAAAaABAABAAFAAcAAAAaABEABAAFAAgAAAA=")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("12_toast_examine1")
ExamineText = "\"Butter, half-melted. A bite missing from the right side — small, a child's bite.\"|\"She was here just a moment ago.\""
DialogueDurationText = "6.0|6.0"
DialogueFontSize = 28

[node name="Note" type="TileMapLayer" parent="Objects" unique_id=1589708906]
texture_filter = 1
scale = Vector2(2, 2)
tile_set = ExtResource("2_hnbyo")

[node name="Clarify1" type="TileMapLayer" parent="Objects/Note" unique_id=1684176798]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAADAAoABAAbABIAAAADAAsABAAbABMAAAADAAwABAAbABQAAAADAA0ABAAbABUAAAAEAAoABAAcABIAAAAEAAsABAAcABMAAAAEAAwABAAcABQAAAAEAA0ABAAcABUAAAAFAAoABAAdABIAAAAFAAsABAAdABMAAAAFAAwABAAdABQAAAAFAA0ABAAdABUAAAA=")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("17_xwh56")
ExamineText = "\"She didn't write it. The reminder she left herself only said when she'd be back.\"|\"The rest — she added it later. She adds it every time she looks.\""
DialogueDurationText = "6.0|6.0"

[node name="Examine2" type="TileMapLayer" parent="Objects/Note" unique_id=1238276835]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAADAAoABAAQABIAAAADAAsABAAQABMAAAADAAwABAAQABQAAAADAA0ABAAQABUAAAAEAAoABAARABIAAAAEAAsABAARABMAAAAEAAwABAARABQAAAAEAA0ABAARABUAAAAFAAoABAASABIAAAAFAAsABAASABMAAAAFAAwABAASABQAAAAFAA0ABAASABUAAAA=")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("13_note_examine2")
ExamineText = "(The second line is shorter than you remember. You may have misread it.)"
