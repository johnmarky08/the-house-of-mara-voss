[node name="Examine3" type="TileMapLayer" parent="Objects/Toast" unique_id=450410329]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("AAAXAA8ABAAOAAYAAAAXABAABAAOAAcAAAAXABEABAAOAAgAAAAYAA8ABAAPAAYAAAAYABAABAAPAAcAAAAYABEABAAPAAgAAAAZAA8ABAAQAAYAAAAZABAABAAQAAcAAAAZABEABAAQAAgAAAAaAA8ABAARAAYAAAAaABAABAARAAcAAAAaABEABAARAAgAAAAbAA8ABAASAAYAAAAbABAABAASAAcAAAAbABEABAASAAgAAAA=")
