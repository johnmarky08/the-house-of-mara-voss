[node name="Clarify1" type="TileMapLayer" parent="Objects/Window" unique_id=1901678332]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("4_xk66e")
ExamineText = "\"The swing was taken down. Something happened to the other tree.\"|\"The garden keeps going without anyone tending it.\""
DialogueDurationText = "6.0|6.0"
DialogueFontSize = 28

[node name="Examine2" type="TileMapLayer" parent="Objects/Window" unique_id=627085884]
modulate = Color(1, 1, 1, 0)
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("5_win_examine2")
ExamineText = "\"Something is different. The light has not changed. The angle of it is wrong for the time on the clock.\""
DialogueDuration = 5.0
DialogueFontSize = 23

[node name="Examine1" type="TileMapLayer" parent="Objects/Window" unique_id=2006738379]
texture_filter = 1
tile_map_data = PackedByteArray("")
tile_set = ExtResource("2_hnbyo")
script = ExtResource("6_win_examine1")
ExamineText = "\"The garden is still.\"|\"The swing moves just slightly — not from wind, maybe, but from the memory of someone having just been on it.\"|\"The apple trees are heavy. It is exactly the right time of year.\""
DialogueDurationText = "3.0|6.0|5.0"
DialogueFontSize = 25

