[node name="Examine1" type="TileMapLayer" parent="Objects/Note" unique_id=190346510]
texture_filter = 1
tile_map_data = PackedByteArray("AAADAAoABAAFABIAAAADAAsABAAFABMAAAADAAwABAAFABQAAAADAA0ABAAFABUAAAAEAAoABAAGABIAAAAEAAsABAAGABMAAAAEAAwABAAGABQAAAAEAA0ABAAGABUAAAAFAAoABAAHABIAAAAFAAsABAAHABMAAAAFAAwABAAHABQAAAAFAA0ABAAHABUAAAA=")
